---
import MainLayout from './landing/layouts/MainLayout.astro';
import HeroSection from './Landing/components/HeroSection.astro';
import Sidebar from './Landing/components/Sidebar.astro';
import DiscoverSection from './Landing/components/DiscoverSection.astro';
import FeaturedSection from './Landing/components/FeaturedSection.astro';
import NewReleasesSection from './Landing/components/NewReleasesSection.astro';
import TestimonialsSection from './Landing/components/TestimonialsSection.astro';
import NewsletterSection from './Landing/components/NewsletterSection.astro';
---

<MainLayout title="Inicio">
  <div class="pt-16">
    <!-- Main content grid -->
    <div class="grid grid-cols-1 md:grid-cols-4">
      <!-- Sidebar - only visible on md and up -->
      <div class="hidden md:block md:col-span-1 p-4 bg-gray-50">
        <Sidebar />
      </div>

      <!-- Main content area -->
      <div class="col-span-1 md:col-span-3">
        <HeroSection />
        <DiscoverSection />
      </div>
    </div>

    <!-- Full width sections -->
    <FeaturedSection />
    <NewReleasesSection />
    <TestimonialsSection />
    <NewsletterSection />
  </div>
</MainLayout>

<style>
  /* Add any page-specific styles here */
</style>
